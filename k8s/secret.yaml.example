apiVersion: v1
kind: Secret
metadata:
  name: bento-secret
  namespace: bento
type: Opaque
data:
  # ── PostgreSQL ──────────────────────────────────────────────────
  # echo -n "Host=postgres;Port=5432;Database=bentodb;Username=bento;Password=YOUR_PG_PASS" | base64
  ConnectionStrings__PostgreSql: <base64_encoded>

  # echo -n "YOUR_PG_PASS" | base64
  POSTGRES_PASSWORD: <base64_encoded>

  # ── Redis ───────────────────────────────────────────────────────
  # echo -n "redis:6379,password=YOUR_REDIS_PASS" | base64
  Redis__ConnectionString: <base64_encoded>

  # echo -n "YOUR_REDIS_PASS" | base64
  REDIS_PASSWORD: <base64_encoded>

  # ── MongoDB ─────────────────────────────────────────────────────
  # echo -n "mongodb://bento:YOUR_MONGO_PASS@mongo:27017" | base64
  Mongo__ConnectionString: <base64_encoded>

  # echo -n "YOUR_MONGO_PASS" | base64
  MONGO_INITDB_ROOT_PASSWORD: <base64_encoded>

  # openssl rand -base64 32 | tr -d '\n' | base64
  Cache__AdminApiKey: <base64_encoded>
