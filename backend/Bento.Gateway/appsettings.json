{
  "ReverseProxy": {
    "Routes": {
      "bento-api-route": {
        "ClusterId": "bento-api-cluster",
        "Match": {
          "Path": "/gateway/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/gateway"
          }
        ]
      }
    },
    "Clusters": {
      "bento-api-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://bento-api:5050/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
