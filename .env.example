# ===== Common =====
ASPNETCORE_ENVIRONMENT=Development
BENTO_NETWORK_NAME=bento-network

# ===== Proxy (for npm / NuGet in corporate network) =====
PROXY_USER=
PROXY_PASS=

# ===== Image names (optional override) =====
BENTO_API_IMAGE=bento-api:latest
BENTO_GATEWAY_IMAGE=bento-gateway:latest
BENTO_CLIENT_IMAGE=bento-client:latest
BENTO_BLAZOR_IMAGE=bento-blazor:latest
NGINX_IMAGE=bento-nginx:latest
JENKINS_IMAGE=bento-jenkins:latest

# ===== Service ports =====
BENTO_API_PORT=5050
BENTO_GATEWAY_PORT=5000
BENTO_CLIENT_PORT=3000
BENTO_BLAZOR_PORT=3001
NGINX_PORT=80
JENKINS_PORT=8080
JENKINS_AGENT_PORT=50000
POSTGRES_PORT=5432
MSSQL_PORT=1433
MARIADB_PORT=3306
MONGO_PORT=27017
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# ===== Database & MQ credentials =====
POSTGRES_USER=bento
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=bentodb

MSSQL_SA_PASSWORD=Your_strong_password_123

MARIADB_ROOT_PASSWORD=your_mariadb_root_password
MARIADB_DATABASE=bentodb
MARIADB_USER=bento
MARIADB_PASSWORD=your_mariadb_password

MONGO_INITDB_ROOT_USERNAME=bento
MONGO_INITDB_ROOT_PASSWORD=your_mongo_password
MONGO_DATABASE=bento_logs
MONGO_ORDER_COLLECTION=order_logs

REDIS_PASSWORD=your_redis_password

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_QUEUE_NAME=order-created

# ===== CORS =====
CORS_ORIGIN_REACT=http://localhost:3000
CORS_ORIGIN_BLAZOR=http://localhost:3001
CORS_ORIGIN_NGINX=http://localhost

# ===== Frontend to Gateway =====
VITE_BENTO_GATEWAY_BASE_URL=http://localhost:5000/gateway
BLAZOR_GATEWAY_BASE_URL=http://bento-gateway:5000/gateway

# ===== Optional container names =====
BENTO_API_CONTAINER_NAME=bento-api
BENTO_GATEWAY_CONTAINER_NAME=bento-gateway
BENTO_CLIENT_CONTAINER_NAME=bento-client
BENTO_BLAZOR_CONTAINER_NAME=bento-blazor
POSTGRES_CONTAINER_NAME=postgres
MSSQL_CONTAINER_NAME=mssql
MARIADB_CONTAINER_NAME=mariadb
MONGO_CONTAINER_NAME=mongo
REDIS_CONTAINER_NAME=redis
RABBITMQ_CONTAINER_NAME=rabbitmq
NGINX_CONTAINER_NAME=bento-nginx
JENKINS_CONTAINER_NAME=jenkins

# ===== Optional image source override =====
POSTGRES_IMAGE=postgres:16-alpine
MSSQL_IMAGE=mcr.microsoft.com/mssql/server:2022-latest
MARIADB_IMAGE=mariadb:11
MONGO_IMAGE=mongo:7
REDIS_IMAGE=redis:7-alpine
RABBITMQ_IMAGE=rabbitmq:3-management

# ===== SQL Server options =====
MSSQL_ACCEPT_EULA=Y
MSSQL_PID=Developer
