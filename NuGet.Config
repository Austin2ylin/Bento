<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <!--
    公司網路若需要 proxy，請在本機環境變數設定 HTTP_PROXY / HTTPS_PROXY，
    不要把 proxy 帳密或內網位址提交到 repository。
  -->
</configuration>
