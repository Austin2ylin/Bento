<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <config>
    <!-- Company proxy with credentials from environment variables -->
    <add key="http_proxy" value="http://%PROXY_USER%:%PROXY_PASS%@194.1.3.3:8080" />
    <add key="https_proxy" value="http://%PROXY_USER%:%PROXY_PASS%@194.1.3.3:8080" />
    <add key="no_proxy" value="localhost,127.0.0.1" />
  </config>
</configuration>
