@page "/menu"
@inject BentoApiService Api

<div class="page-header">
    <h2>菜單管理</h2>
    <p>目前供應的便當品項</p>
</div>

<div class="section-header">
    <h3 class="section-title">品項列表</h3>
    <button class="btn btn-ghost btn-sm" @onclick="LoadAsync">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12a9 9 0 019-9 9.75 9.75 0 016.74 2.74L21 8"/>
            <path d="M21 3v5h-5"/>
            <path d="M21 12a9 9 0 01-9 9 9.75 9.75 0 01-6.74-2.74L3 16"/>
            <path d="M3 21v-5h5"/>
        </svg>
        重新整理
    </button>
</div>

<div class="table-wrap">
    @if (loading)
    {
        <div class="empty-row" style="padding:32px;text-align:center;color:var(--text-3);font-size:13px">載入中...</div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>名稱</th>
                    <th>售價</th>
                    <th>供應狀態</th>
                </tr>
            </thead>
            <tbody>
                @if (menu.Count == 0)
                {
                    <tr class="empty-row"><td colspan="4">目前沒有菜單品項</td></tr>
                }
                else
                {
                    @foreach (var item in menu)
                    {
                        <tr>
                            <td class="td-muted">@item.Id</td>
                            <td class="td-strong">@item.Name</td>
                            <td>NT$&nbsp;@item.Price.ToString("N0")</td>
                            <td>
                                @if (item.IsAvailable)
                                {
                                    <span class="badge badge-on">供應中</span>
                                }
                                else
                                {
                                    <span class="badge badge-off">停售</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<MenuItemDto> menu = new();
    private bool loading;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        loading = true;
        menu    = await Api.GetMenuAsync();
        loading = false;
    }
}
